# Required for SQL generation (Groq recommended)
GROQ_API_KEY=your-groq-api-key-here
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional Anthropic fallback
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional
ENCRYPTION_KEY=

# MongoDB — single source of truth for query history, analysis results,
# chat messages, connections, API keys, and app preferences.
# Default: mongodb://localhost:27017/prepsql
MONGODB_URI=mongodb://localhost:27017/prepsql
